---
layout: base.njk
bodyClass: "bg-surface font-body"
---
<main class="max-w-3xl mx-auto px-8 py-16">
  <header class="mb-12">
    <div class="mb-6">
      <a href="/blog/" class="inline-flex items-center gap-1.5 text-sm text-secondary hover:text-primary transition-colors">
        <span class="material-symbols-outlined text-base">arrow_back</span>
        All Posts
      </a>
    </div>
    <h1 class="font-headline text-4xl md:text-5xl text-[#2B2B2B] leading-tight mb-6">{{ title }}</h1>
    <div class="flex flex-wrap items-center gap-4 mb-8">
      <time class="text-xs font-label tracking-widest text-on-surface-variant opacity-60 uppercase">{{ page.date | dateString }}</time>
      {% if tags and tags.length %}
      <div class="flex flex-wrap gap-2">
        {% for tag in tags %}
        <span class="px-3 py-0.5 bg-secondary-container text-on-secondary-container text-xs rounded-full">{{ tag }}</span>
        {% endfor %}
      </div>
      {% endif %}
    </div>
    <div class="h-0.5 w-16 bg-primary"></div>
  </header>

  <article class="prose prose-stone max-w-none
    prose-headings:font-serif prose-headings:text-[#2B2B2B] prose-headings:font-normal
    prose-p:text-[#2B2B2B]/80 prose-p:leading-relaxed
    prose-a:text-primary prose-a:no-underline hover:prose-a:underline
    prose-strong:text-[#2B2B2B]
    prose-code:text-primary prose-code:bg-surface-container prose-code:before:content-none prose-code:after:content-none prose-code:px-1 prose-code:py-0.5 prose-code:rounded
    prose-pre:bg-surface-container prose-pre:text-[#2B2B2B]
    prose-blockquote:border-primary prose-blockquote:text-[#2B2B2B]/70
    prose-hr:border-outline-variant">
    {{ content | safe }}
  </article>

  <footer class="mt-16 pt-8 border-t border-outline-variant/20">
    <a href="/blog/" class="inline-flex items-center gap-2 text-sm text-secondary hover:text-primary transition-colors group">
      <span class="material-symbols-outlined text-base group-hover:-translate-x-1 transition-transform">arrow_back</span>
      Back to all posts
    </a>
  </footer>
</main>
